{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "45a69dc3405247d9a46bc1e7b4133f31",
    "m_Title": "Changing Dissolve Direction",
    "m_Content": "We are using the Split Node to Split the Global Position and store the values to R G B Channel as X Y and Z respectively.\n\nBy Default the Direction of the Dissolve is set to Vertical Y Direction.\n\nYou can change it to Horizontal X Direction by connecting the R from Split Node to Add and Step Node instead of G.\n\nSame concept you can apply to Z Direction for the Overall Dissolve.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -2732.0,
        "y": 479.0,
        "width": 252.89990234375,
        "height": 282.99249267578127
    },
    "m_Group": {
        "m_Id": "3b566ae6e21a43bf8704c2bbedb4e296"
    }
}

